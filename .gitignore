.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# 微信小程序编译产物
/dist/

# 本地配置文件（包含 appid 等敏感信息）
/miniprogram/config.*
/miniprogram/.env*
/weapp/.env*

# 微信开发者工具私有配置（包含 appid 等）
project.private.config.json
project.config.json

# node_modules 依赖
node_modules/

# npm/yarn 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
package-lock.json
pnpm-lock.yaml

# 微信开发者工具日志
/traces/
//crash/

