/* 全局页面背景 */
page {
  background-color: #F5F7FA;
}

.page-container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 200rpx;
}

/* 通用卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

/* 分区标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

/* 预览区域 */
.preview-section {
  margin-bottom: 24rpx;
}

.preview-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #E8ECEF;
  border-radius: 16rpx;
  padding: 40rpx;
  min-height: 500rpx;
}

.preview-card {
  width: 360rpx;
  height: 480rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.preview-text {
  text-align: center;
  word-break: break-all;
  line-height: 1.6;
}

/* 编辑区域 */
.edit-section {
  padding: 30rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.edit-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.char-count {
  font-size: 24rpx;
  color: #999999;
}

.text-input {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  background-color: #F5F7FA;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.placeholder {
  color: #CCCCCC;
}

.action-btns {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  text-align: center;
  min-width: 100rpx;
}

.action-btn-clear {
  color: #ff6b6b;
  background-color: rgba(255, 107, 107, 0.1);
}

.action-btn-paste {
  color: #4ecdc4;
  background-color: rgba(78, 205, 196, 0.1);
}

.action-btn-copy {
  color: #2E5EFF;
  background-color: rgba(46, 94, 255, 0.1);
}

.hover {
  opacity: 0.7;
}

/* 模板选择 */
.template-section {
  padding: 30rpx;
}

.template-list {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin: 0 -15rpx;
}

.template-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 15rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.template-item.active {
  border-color: #2E5EFF;
  background-color: rgba(46, 94, 255, 0.05);
}

.template-preview {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.template-text {
  font-size: 24rpx;
  font-weight: 600;
}

.template-name {
  font-size: 22rpx;
  color: #4C4C4C;
}

.template-item.active .template-name {
  color: #2E5EFF;
  font-weight: 600;
}

/* 历史记录入口 */
.history-section {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #4C4C4C;
}

.history-count {
  font-size: 24rpx;
  color: #999999;
  background-color: #F5F7FA;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.history-tip {
  font-size: 20rpx;
  color: #CCCCCC;
  margin-left: 8rpx;
}

/* 底部安全区 */
.bottom-safe-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 自定义按钮 */
.custom-btn {
  background-color: #2E5EFF;
  color: #FFFFFF;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 16rpx rgba(46, 94, 255, 0.15);
}

.custom-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.modal-overlay.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999999;
  background-color: #F5F7FA;
  border-radius: 50%;
}

.history-list {
  max-height: 60vh;
  padding: 24rpx;
}

.empty-history {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #F5F7FA;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.history-item-content {
  width: 100rpx;
  height: 133rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-item-text {
  font-size: 16rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.history-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.history-item-template {
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.history-item-date {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* Canvas 容器 */
/* Canvas - 固定在底部可见区域外，但保持渲染 */
.card-canvas {
  position: fixed;
  left: 0;
  bottom: -800px;
  width: 600px;
  height: 800px;
}